@startuml Activity Diagram
!theme plain
skinparam backgroundColor #FEFEFE

start

:User types message;
:User selects cover image;

if (Image valid?) then (yes)
    :Encrypt message with secret key;
    :Encode encrypted text into image using steganography;
    :Send encoded image via Socket.IO;
    :Save message locally to IndexedDB;
    :Display sent message in chat;
else (no)
    :Show error: Invalid image;
endif

:Server broadcasts message to room members;

partition "Receiver Side" {
    :Receive image message;
    :Attempt to decode hidden message from image;
    if (Decoding successful?) then (yes)
        :Decrypt message with secret key;
        if (Decryption successful?) then (yes)
            :Display decrypted message;
            :Play notification sound;
        else (no)
            :Display as plain image;
        endif
    else (no)
        :Display as plain image;
    endif
}

:End;

stop
@enduml
