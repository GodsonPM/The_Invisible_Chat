@startuml Package Diagram
!theme plain
skinparam backgroundColor #FEFEFE

package "invisible-chat" as root {
    package "src" as src {
        package "components" as components {
            artifact App.jsx
            artifact HiddenChat.jsx
            artifact CoverFeed.jsx
        }
        package "utils" as utils {
            artifact steganography.js
            artifact crypto.js
            artifact db.js
            artifact sound.js
        }
        artifact main.jsx
        artifact index.css
    }
    package "server" as server {
        artifact index.js
    }
    package "docs" as docs {
        package "chapter2" as chapter2 {
            artifact "*.md files"
            artifact "*.puml files"
        }
    }
    artifact package.json
    artifact vite.config.js
}

components --> utils : uses
src --> server : connects via Socket.IO

note right of components
    React components
    for UI
end note

note right of utils
    Utility functions
    for stego, crypto, storage
end note

note right of server
    Node.js server
    with Socket.IO
end note
@enduml
